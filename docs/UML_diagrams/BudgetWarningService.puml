@startuml
title BudgetWarningService
hide footbox

actor User

participant ":Finbro" as Finbro
participant ":BudgetWarningService" as BudgetWarningService
participant ":Limit" as Limit
participant ":ExpenseList" as ExpenseList
participant ":Ui" as Ui

loop After each successful command (and once at startup)
    Finbro -> BudgetWarningService++ : checkAndShowWarnings(expenses, ui, checksBudget)

    alt checksBudget == false
        BudgetWarningService --> Finbro : return
    else checksBudget == true
        BudgetWarningService -> Limit : getLimit()
        activate Limit
        Limit --> BudgetWarningService : 0 or non-zero
        deactivate Limit

        alt limit == 0
            BudgetWarningService --> Finbro : return
        else limit != 0
            BudgetWarningService -> ExpenseList : getCurrentMonthTotalExpenditure()
            activate ExpenseList
            ExpenseList --> BudgetWarningService : monthlyTotal
            deactivate ExpenseList

            BudgetWarningService -> Limit : getLimit()
            activate Limit
            Limit --> BudgetWarningService : limit
            deactivate Limit

            alt monthlyTotal > limit
                BudgetWarningService -> Ui : showBudgetExceeded(limit)
                activate Ui
                Ui --> User : display exceeded warning
                deactivate Ui

            else limit - monthlyTotal <= 20
                BudgetWarningService -> Ui : showBudgetReminder(limit)
                activate Ui
                Ui --> User : display reminder warning
                deactivate Ui

            else limit - monthlyTotal > 20
                note right of BudgetWarningService
                    No UI warning shown.
                end note
            end
        end
    end

    BudgetWarningService --> Finbro--
end
@enduml
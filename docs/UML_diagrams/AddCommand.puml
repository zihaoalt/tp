@startuml AddCommand
'https://plantuml.com/sequence-diagram
actor User


participant ":Ui"
participant ":Finbro"
participant ":Parser"
participant "c:AddCommand"
participant ":ExpenseList"
participant ":Storage"



activate ":Finbro"
":Finbro" -> ":Ui" : readCommand()
activate ":Ui"
User -> ":Ui" : type "add ..."
":Ui" --> ":Finbro" : input
deactivate ":Ui"

":Finbro" -> ":Parser" : parse(input)
activate ":Parser"

create "c:AddCommand"
":Parser" -> "c:AddCommand" : new AddCommand(argument)
activate "c:AddCommand"
return c
return c

":Finbro" -> "c:AddCommand" ++ : execute(...)

alt walkthrough mode [arg.isBlank()]
    loop for each field (amount, category, date)
        "c:AddCommand" -> ":Ui" ++ : showEnterXPrompt()
        return
        "c:AddCommand" -> ":Ui" ++ : readCommand()
        ":Ui" -> User : prompt
        User -> ":Ui" : input field
        return field
    end
else direct mode
    "c:AddCommand" -> "c:AddCommand" ++ : verifyInputLength / verifyAmount / verifyDate
    return
end

"c:AddCommand" -> ":Ui" ++ : showConfirmExpense(expense)
return

"c:AddCommand" -> ":Ui" ++ : readCommand()
":Ui" -> User : confirm prompt
User -> ":Ui" : confirm response
return confirm

alt confirm == "yes"
    "c:AddCommand" -> ":ExpenseList" ++ : add(expense)
    ":ExpenseList" -> ":ExpenseList" ++ : updateTotals()
    return
    return
    "c:AddCommand" -> ":Ui" ++ : showExpenseAdded(...)
    return
else
    "c:AddCommand" -> ":Ui" ++ : showCancelAddMessage()
    return
end

return

":Finbro" -> ":Storage" ++ : save()
":Storage" -> ":ExpenseList" ++ : toFileFormat()
return
return

return

@enduml
